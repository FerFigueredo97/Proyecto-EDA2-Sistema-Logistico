# ==========================
#  IGNORAR ARCHIVOS TEMPORALES DE VS
# ==========================
# Carpeta de configuración interna de Visual Studio
.vs/

# Ignorar ejecutables y compilados
*.exe
*.out
*.app
*.o
*.obj
*.tds

# Ignorar carpetas de compilación de Visual Studio
Debug/
Release/
x64/
*.log
*.tlog
*.pdb
*.idb

# Ignorar archivos de usuario de Visual Studio
*.suo
*.user
*.vcxproj.user
*.sln.docstates

# Compiled Object files (repetidos, los dejé una sola vez)
*.slo
*.lo

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files (ya cubierto con *.pdb, pero lo dejo por claridad)
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll
*.so.*

# Fortran module files (por si alguna librería los usa)
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Build directories
build/
Build/
build-*/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json

# Temporary files
*.tmp
*.bak
*.swp

# vcpkg
vcpkg_installed/

# Debug information files
*.dwo

# Test output & cache
Testing/
.cache/
